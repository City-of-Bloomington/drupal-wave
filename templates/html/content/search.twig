{% extends "html/layouts/default.twig" %}
{% import  "html/macros/pagination.twig" as pagination %}
{% import  "html/macros/forms.twig"      as forms      %}
{% block content %}
<section>
    <header><h1>Website Content</h1></header>

    <form class="usa-search" role="search">
        <label class="usa-sr-only" for="query">Search</label>
        <input class="usa-input"    id="query" name="query" type="search" value="{{ query }}" />
        <button class="usa-button" type="submit">
            <span class="usa-search__submit-text">Search </span>
            <img src="{{ USWDS_URL }}/assets/img/usa-icons-bg/search--white.svg" class="usa-search__submit-icon" alt="Search" />
        </button>
    </form>

    {% if query %}

        {% if reports %}
        <h2>Webages Found</h2>
        <table class="usa-table usa-table--compact">
        <thead>
            <tr><th>Page</th>
                <th>Errors</th>
                <th>Contrast</th>
                <th>PDF Problems</th>
                <th>Last Editor</th>
                <th>Department</th>
                <th>Scanned</th>
                <th>Views (2025)</th>
            </tr>
        </thead>
        <tbody>
            {% for r in reports %}
            <tr><td><a href="{{ DRUPAL_SITE }}{{ r.path }}">{{ r.path }}</a></td>
                <td>{{ r.error    ? r.error    : '' }}</td>
                <td>{{ r.contrast ? r.contrast : '' }}</td>
                <td>{% if r.pdf %}
                    <a href="{{ uri('home.info', { id:r.id }) }}">{{ r.pdf }}</a>
                    {% endif %}
                </td>
                <td>{{ r.username   }}</td>
                <td>{{ r.department }}</td>
                <td>{{ r.created | date('n/j/Y') }}</td>
                <td>{{ r.views }}</td>
            </tr>
            {% endfor %}
        </tbody>
        </table>
        {% endif %}

    {% else %}
    <p>No webpages found.</p>
    {% endif %}
</section>
{% endblock %}
